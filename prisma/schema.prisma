datasource db {
  provider = "postgresql"
 
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. MODULE UTILISATEURS & AUTHENTIFICATION
// ==========================================

model User {
  id              String             @id @default(uuid())
  email           String             @unique
  password        String
  role            String             // "student", "investor", "admin"
  kycValidated    Boolean            @default(false)
  reputationScore Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  profile         UserProfile?
  badges          UserBadge[]
  projects        Project[]
  likes           ProjectLike[]
  saves           ProjectSave[]
  comments        Comment[]
  conversations   Conversation[]     @relation("UserConversations")
  messages        Message[]
  collaborations  Collaboration[]
  applications    RequestApplication[]
  reports         Report[]
}

model UserProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  university         String?
  skills             String[] 
  bio                String?
  cvUrl              String?  
  linkedinUrl        String?
  companyName        String?  
  investmentCriteria String?  
}

model UserBadge {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeName   String   
  iconUrl     String?
  points      Int      @default(0)
  awardedAt   DateTime @default(now())
}

// ==========================================
// 2. MODULE PROJETS & ENGAGEMENT SOCIAL
// ==========================================

model Project {
  id            String         @id @default(uuid())
  title         String
  description   String
  category      String
  businessModel String
  budgetGoal    Float
  fundsRaised   Float          @default(0)
  isVisible     Boolean        @default(false) 
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // Correction IA : Type Json pour éviter le problème d'extension pgvector
  embedding     Json?

  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  likes         ProjectLike[]
  saves         ProjectSave[]
  comments      Comment[]
  investments   Investment[]
  milestones    EscrowMilestone[]
  collaborations Collaboration[]
  conversations Conversation[]
}

model ProjectLike {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model ProjectSave {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Comment {
  id        String    @id @default(uuid())
  text      String
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?   
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime  @default(now())
}

model FeedEvent {
  id        String   @id @default(uuid())
  eventType String   
  payload   Json     
  createdAt DateTime @default(now())
}

// ==========================================
// 3. MODULE FINANCES & ESCROW SECURISÉ
// ==========================================

model Investment {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  investorId    String
  amount        Float
  currency      String   
  method        String   
  escrowStatus  String   
  createdAt     DateTime @default(now())
}

model PaymentTransaction {
  id            String   @id @default(uuid())
  providerTxId  String   @unique 
  amount        Float
  status        String   
  rawWebhookLog Json     
  createdAt     DateTime @default(now())
}

model EscrowMilestone {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  amountShare Float    
  status      String   
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 4. MODULE MESSAGERIE TEMPS RÉEL (Socket.io)
// ==========================================

model Conversation {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users     User[]    @relation("UserConversations")
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id             String            @id @default(uuid())
  conversationId String
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  mediaUrl       String?           
  createdAt      DateTime          @default(now())
  reactions      MessageReaction[]
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  emoji     String   
  userId    String
}

// ==========================================
// 5. MODULE COLLABORATION & MARKETPLACE
// ==========================================

model Collaboration {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studentId    String
  student      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  roleInTeam   String   
  status       String   
  createdAt    DateTime @default(now())
}

model InvestorRequest {
  id           String               @id @default(uuid())
  title        String
  description  String
  type         String               
  budget       Float?
  createdAt    DateTime             @default(now())
  applications RequestApplication[]
}

model RequestApplication {
  id          String          @id @default(uuid())
  requestId   String
  request     InvestorRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  studentId   String
  student     User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  coverLetter String
  status      String          
  createdAt   DateTime        @default(now())
}

model Appointment {
  id         String   @id @default(uuid())
  hostId     String
  guestId    String
  scheduledAt DateTime
  duration   Int      
  meetUrl    String?  
  status     String   
  createdAt  DateTime @default(now())
}

// ==========================================
// 6. ACADEMY, MODÉRATION & SECURITÉ (AUDIT)
// ==========================================

model AcademyCourse {
  id          String   @id @default(uuid())
  title       String
  description String
  contentUrl  String?  
  isPremium   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ForumPost {
  id        String   @id @default(uuid())
  title     String
  content   String
  authorId  String
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType  String   
  targetId    String   
  reason      String
  severity    String   
  status      String   
  createdAt   DateTime @default(now())
}

model ReportAuditLog { 
  id        String   @id @default(uuid())
  actorId   String   
  ipAddress String?
  action    String   
  oldValues Json?    
  newValues Json?    
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   
  auth      String   
  createdAt DateTime @default(now())
}

